{
  "$schema": "https://schemas.wp.org/wp/6.8/theme.json",
  "version": 3,
  "customTemplates": [
    {
      "name": "blank-page",
      "postTypes": ["page", "post"],
      "title": "Blank Page"
    }
  ],
  "templateParts": [
    {
      "name": "header",
      "title": "Header",
      "area": "header"
    },
    {
      "name": "footer",
      "title": "Footer",
      "area": "footer"
    }
  ],
  "settings": {
    "appearanceTools": true,
    "useRootPaddingAwareAlignments": true,
    "custom": true,
    "customDuotone": false,
    "customGradient": false,
    "defaultDuotone": false,
    "defaultGradients": false,
    "defaultPalette": false,
    "color": {
      "palette": [
        {
          "slug": "base",
          "color": "#ffffff",
          "name": "Base"
        },
        {
          "slug": "contrast",
          "color": "#1f2937",
          "name": "Contrast"
        },
        {
          "slug": "primary",
          "color": "#83c3d0",
          "name": "Primary"
        },
        {
          "slug": "secondary",
          "color": "#f8fbc3",
          "name": "Secondary"
        },
        {
          "slug": "accent",
          "color": "#1a4c43",
          "name": "Accent"
        },
        {
          "slug": "muted",
          "color": "#83c3d073",
          "name": "Muted"
        }
      ]
    },
    "typography": {
      "customFontSize": true,
      "customLineHeight": true,
      "dropCap": false,
      "fluid": true,
      "defaultFontSizes": false,
      "fontFamilies": [
        {
          "slug": "heading",
          "name": "Heading",
          "fontFamily": "'Montserrat', sans-serif",
          "fontFace": [
            {
              "fontFamily": "Montserrat",
              "fontStyle": "normal",
              "fontWeight": "400",
              "src": ["file:./assets/fonts/Montserrat/static/Montserrat-Regular.ttf"]
            },
            {
              "fontFamily": "Montserrat",
              "fontStyle": "normal",
              "fontWeight": "500",
              "src": ["file:./assets/fonts/Montserrat/static/Montserrat-Medium.ttf"]
            },
            {
              "fontFamily": "Montserrat",
              "fontStyle": "normal",
              "fontWeight": "700",
              "src": ["file:./assets/fonts/Montserrat/static/Montserrat-Bold.ttf"]
            }
          ]
        },
        {
          "slug": "body",
          "name": "Body",
          "fontFamily": "'Montserrat', sans-serif",
          "fontFace": [
            {
              "fontFamily": "Montserrat",
              "fontStyle": "normal",
              "fontWeight": "400",
              "src": ["file:./assets/fonts/Montserrat/static/Montserrat-Regular.ttf"]
            },
            {
              "fontFamily": "Montserrat",
              "fontStyle": "normal",
              "fontWeight": "500",
              "src": ["file:./assets/fonts/Montserrat/static/Montserrat-Medium.ttf"]
            },
            {
              "fontFamily": "Montserrat",
              "fontStyle": "normal",
              "fontWeight": "700",
              "src": ["file:./assets/fonts/Montserrat/static/Montserrat-Bold.ttf"]
            }
          ]
        },
        {
          "slug": "serif",
          "name": "Serif",
          "fontFamily": "'Cardo', serif",
          "fontFace": [
            {
              "fontFamily": "Cardo",
              "fontStyle": "normal",
              "fontWeight": "400",
              "src": ["file:./assets/fonts/Cardo/Cardo_Regular.ttf"]
            },
            {
              "fontFamily": "Cardo",
              "fontStyle": "italic",
              "fontWeight": "400",
              "src": ["file:./assets/fonts/Cardo/Cardo_Italic.ttf"]
            },
            {
              "fontFamily": "Cardo",
              "fontStyle": "normal",
              "fontWeight": "700",
              "src": ["file:./assets/fonts/Cardo/Cardo_Bold.ttf"]
            }
          ]
        },
        {
          "fontFace": [
            {
              "fontFamily": "Icon-Font",
              "fontStyle": "normal",
              "fontWeight": "400",
              "src": ["file:./assets/fonts/icon-font/icon-font-400-normal.woff"]
            }
          ],
          "slug": "icon-font",
          "name": "Icon-Font",
          "fontFamily": "Icon-Font"
        }
      ],
      "fontSizes": [
        {
          "slug": "xs",
          "size": "0.75rem",
          "name": "Extra Small"
        },
        {
          "slug": "sm",
          "size": "0.875rem",
          "name": "Small"
        },
        {
          "slug": "base",
          "size": "1rem",
          "name": "Base"
        },
        {
          "slug": "lg",
          "size": "1.125rem",
          "name": "Large"
        },
        {
          "slug": "xl",
          "size": "1.25rem",
          "name": "Extra Large"
        },
        {
          "slug": "xxl",
          "size": "1.5rem",
          "name": "2XL"
        },
        {
          "slug": "xxxl",
          "size": "1.875rem",
          "name": "3XL"
        },
        {
          "slug": "xxxxl",
          "size": "2.25rem",
          "name": "4XL"
        }
      ]
    },
    "layout": {
      "contentSize": "800px",
      "wideSize": "1200px"
    },
    "spacing": {
      "customSpacingSize": true,
      "defaultSpacingSizes": false,
      "spacingScale": {
        "steps": 0
      },
      "spacingSizes": [
        {
          "slug": "10",
          "size": "0.25rem",
          "name": "1"
        },
        {
          "slug": "20",
          "size": "0.5rem",
          "name": "2"
        },
        {
          "slug": "30",
          "size": "0.75rem",
          "name": "3"
        },
        {
          "slug": "40",
          "size": "1rem",
          "name": "4"
        },
        {
          "slug": "50",
          "size": "1.25rem",
          "name": "5"
        },
        {
          "slug": "60",
          "size": "1.5rem",
          "name": "6"
        },
        {
          "slug": "80",
          "size": "2rem",
          "name": "8"
        },
        {
          "slug": "100",
          "size": "2.5rem",
          "name": "10"
        },
        {
          "slug": "120",
          "size": "3rem",
          "name": "12"
        },
        {
          "slug": "160",
          "size": "4rem",
          "name": "16"
        }
      ],
      "units": ["px", "rem", "em", "vh", "vw", "%"]
    },
    "blocks": {}
  },
  "styles": {
    "spacing": {
      "padding": {
        "top": "0",
        "right": "clamp(1.5rem, 4vw, 3rem)",
        "bottom": "0",
        "left": "clamp(1.5rem, 4vw, 3rem)"
      }
    },
    "typography": {
      "fontFamily": "var(--wp--preset--font-family--body)",
      "fontSize": "var(--wp--preset--font-size--base)"
    },
    "color": {
      "background": "var(--wp--preset--color--base)",
      "text": "var(--wp--preset--color--contrast)"
    },
    "elements": {
      "h1": {
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--heading)",
          "fontSize": "var(--wp--preset--font-size--xxxxl)",
          "lineHeight": "1.1"
        }
      },
      "h2": {
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--heading)",
          "fontSize": "var(--wp--preset--font-size--xxxl)",
          "lineHeight": "1.15"
        }
      },
      "h3": {
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--heading)",
          "fontSize": "var(--wp--preset--font-size--xxl)",
          "lineHeight": "1.2"
        }
      },
      "h4": {
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--heading)",
          "fontSize": "var(--wp--preset--font-size--xl)",
          "lineHeight": "1.25"
        }
      },
      "h5": {
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--heading)",
          "fontSize": "var(--wp--preset--font-size--lg)",
          "lineHeight": "1.3"
        }
      },
      "h6": {
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--heading)",
          "fontSize": "var(--wp--preset--font-size--base)",
          "lineHeight": "1.3"
        }
      },
      "button": {
        "border": {
          "color": "var(--wp--preset--color--transparent)",
          "radius": "4px",
          "style": "solid",
          "width": "4px"
        },
        "color": {
          "background": "var(--wp--preset--color--contrast)",
          "text": "var(--wp--preset--color--base)"
        },
        "shadow": "var(--wp--preset--shadow--natural)",
        "spacing": {
          "padding": {
            "top": "var(--wp--preset--spacing--30)",
            "right": "var(--wp--preset--spacing--30)",
            "bottom": "var(--wp--preset--spacing--30)",
            "left": "var(--wp--preset--spacing--30)"
          }
        },
        "typography": {
          "fontSize": "var(--wp--preset--font-size--sm)",
          "fontWeight": "700"
        }
      },
      "caption": {
        "color": {
          "text": "var(--wp--preset--color--contrast)"
        }
      },
      "cite": {
        "color": {
          "text": "var(--wp--preset--color--contrast)"
        }
      },
      "link": {
        "color": {
          "text": "var(--wp--preset--color--contrast)"
        },
        ":hover": {
          "color": {
            "text": "var(--wp--preset--color--accent)"
          },
          "typography": {
            "textDecoration": "none"
          }
        },
        ":focus": {
          "color": {
            "text": "var(--wp--preset--color--accent)"
          }
        },
        ":active": {
          "color": {
            "text": "var(--wp--preset--color--accent)"
          }
        }
      }
    },
    "blocks": {
      "core/heading": {
        "spacing": {
          "margin": {
            "top": "0",
            "bottom": "0.5em"
          }
        }
      },
      "core/button": {
        "border": {
          "bottom": {
            "color": "#1f2937",
            "style": "solid",
            "width": "2px"
          },
          "left": {
            "color": "#1f2937",
            "style": "solid",
            "width": "2px"
          },
          "right": {
            "color": "#1f2937",
            "style": "solid",
            "width": "2px"
          },
          "top": {
            "color": "#1f2937",
            "style": "solid",
            "width": "2px"
          },
          "radius": {
            "topLeft": "10px",
            "topRight": "10px",
            "bottomLeft": "10px",
            "bottomRight": "10px"
          }
        },
        "color": {
          "background": "var(--wp--preset--color--contrast)",
          "text": "var(--wp--preset--color--base)"
        },
        "elements": {
          "link": {
            "color": {
              "text": "var(--wp--preset--color--base)"
            }
          }
        },
        "shadow": "none",
        "spacing": {
          "padding": {
            "top": "0.6rem",
            "right": "1.5rem",
            "bottom": "0.7rem",
            "left": "1.5rem"
          }
        },
        "typography": {
          "fontSize": "var(--wp--preset--font-size--sm)",
          "fontStyle": "normal",
          "fontWeight": "400",
          "lineHeight": "1.2"
        },
        "variations": {
          "outline": {
            "border": {
              "bottom": {
                "color": "currentColor",
                "style": "solid"
              },
              "left": {
                "color": "currentColor",
                "style": "solid"
              },
              "right": {
                "color": "currentColor",
                "style": "solid"
              },
              "top": {
                "color": "currentColor",
                "style": "solid"
              }
            },
            "spacing": {
              "padding": {
                "top": "0.6rem",
                "right": "1.5rem",
                "bottom": "0.7rem",
                "left": "1.5rem"
              }
            },
            "typography": {
              "lineHeight": "1.2"
            }
          }
        }
      },
      "core/code": {
        "border": {
          "radius": "10px"
        },
        "color": {
          "background": "var(--wp--preset--color--secondary)"
        },
        "spacing": {
          "padding": {
            "top": "var(--wp--preset--spacing--60)",
            "right": "var(--wp--preset--spacing--60)",
            "bottom": "var(--wp--preset--spacing--60)",
            "left": "var(--wp--preset--spacing--60)"
          }
        },
        "typography": {
          "fontSize": "1rem"
        }
      },
      "core/details": {
        "spacing": {
          "blockGap": "5px"
        }
      },
      "core/list-item": {
        "spacing": {
          "margin": {
            "bottom": "0.5rem"
          }
        },
        "typography": {
          "lineHeight": "1.5"
        }
      },
      "core/navigation": {
        "elements": {
          "link": {
            "color": {
              "text": "var(--wp--preset--color--contrast)"
            },
            "typography": {
              "textDecoration": "none"
            },
            ":hover": {
              "color": {
                "text": "var(--wp--preset--color--accent)"
              },
              "typography": {
                "textDecoration": "none"
              }
            },
            ":focus": {
              "color": {
                "text": "var(--wp--preset--color--accent)"
              }
            },
            ":active": {
              "color": {
                "text": "var(--wp--preset--color--accent)"
              }
            }
          }
        },
        "typography": {
          "fontSize": "var(--wp--preset--font-size--base)"
        }
      },
      "core/paragraph": {
        "spacing": {
          "margin": {
            "bottom": "0"
          }
        },
        "typography": {
          "lineHeight": "1.6"
        }
      },
      "core/pullquote": {
        "border": {
          "top": {
            "color": "var(--wp--preset--color--muted)",
            "style": "solid",
            "width": "3px"
          }
        },
        "css": "display: grid;\ngap: 20px;\n",
        "spacing": {
          "padding": {
            "top": "var(--wp--preset--spacing--30)",
            "bottom": "var(--wp--preset--spacing--60)"
          }
        },
        "typography": {
          "fontSize": "var(--wp--preset--font-size--xl)"
        }
      },
      "core/quote": {
        "border": {
          "left": {
            "color": "var(--wp--preset--color--contrast)",
            "style": "solid",
            "width": "4px"
          }
        },
        "spacing": {
          "blockGap": "var(--wp--preset--spacing--30)",
          "margin": {
            "top": "var(--wp--preset--spacing--60)",
            "bottom": "var(--wp--preset--spacing--60)"
          },
          "padding": {
            "top": "0.5rem",
            "right": "var(--wp--preset--spacing--60)",
            "bottom": "0.5rem",
            "left": "var(--wp--preset--spacing--60)"
          }
        },
        "typography": {
          "fontSize": "var(--wp--preset--font-size--xxl)",
          "fontStyle": "normal",
          "fontWeight": "300"
        }
      },
      "core/search": {
        "css": ".wp-block-search__button-inside .wp-block-search__inside-wrapper{border: none;}",
        "typography": {
          "lineHeight": "1"
        }
      },
      "core/site-title": {
        "typography": {
          "fontSize": "var(--wp--preset--font-size--xxl)",
          "fontStyle": "normal",
          "fontWeight": "700",
          "letterSpacing": "-1px"
        }
      },
      "core/post-content": {
        "spacing": {
          "margin": {
            "top": "0",
            "bottom": "0"
          }
        }
      },
      "core/post-template": {
        "spacing": {
          "padding": {
            "top": "0",
            "bottom": "0"
          }
        }
      },
      "core/post-title": {
        "typography": {
          "lineHeight": "1.2"
        }
      },
      "core/post-excerpt": {
        "elements": {
          "link": {
            "typography": {
              "fontSize": "var(--wp--preset--font-size--sm)"
            }
          }
        }
      },
      "core/post-featured-image": {
        "spacing": {
          "margin": {
            "bottom": "0"
          }
        }
      },
      "core/post-terms": {
        "typography": {
          "fontSize": "var(--wp--preset--font-size--sm)"
        }
      },
      "core/post-date": {
        "typography": {
          "fontSize": "var(--wp--preset--font-size--sm)"
        }
      },
      "core/post-author-name": {
        "typography": {
          "fontSize": "var(--wp--preset--font-size--sm)"
        }
      },
      "core/comment-author-name": {
        "typography": {
          "fontSize": "var(--wp--preset--font-size--sm)"
        }
      },
      "core/comment-date": {
        "typography": {
          "fontSize": "var(--wp--preset--font-size--sm)"
        }
      },
      "core/comment-edit-link": {
        "typography": {
          "fontSize": "var(--wp--preset--font-size--sm)"
        }
      },
      "core/comment-reply-link": {
        "typography": {
          "fontSize": "var(--wp--preset--font-size--sm)"
        }
      }
    }
  }
}
